#!/usr/bin/env sh
# pre-commit hook: verify that all staged *.comp files are parse-clean and
# C-code-block formatted according to the official McCode clang-format config.
#
# Install this hook by running (from the repo root):
#   cp hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use the helper script:
#   python hooks/install.py

set -e

# Collect staged *.comp files (added, copied, modified — not deleted).
COMP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.comp$' || true)

if [ -z "$COMP_FILES" ]; then
    exit 0
fi

# Check that mcfmt is available.
if ! command -v mcfmt >/dev/null 2>&1; then
    echo "pre-commit: 'mcfmt' not found — skipping component format check." >&2
    echo "  Install it with: pip install mccode-antlr" >&2
    exit 0
fi

echo "pre-commit: checking McCode component format (mcfmt --check --clang-format)..."

# shellcheck disable=SC2086
if ! mcfmt --check --clang-format $COMP_FILES; then
    echo "" >&2
    echo "pre-commit: one or more .comp files failed the format check." >&2
    echo "  Run 'mcfmt -i --clang-format <file>' to fix them, then re-stage." >&2
    exit 1
fi

echo "pre-commit: all component files passed."
